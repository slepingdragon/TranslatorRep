<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Network -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Audio capture (FR-11) -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />

    <!-- Camera (FR-27, FR-30 — lazy permission flow per ADR-E3) -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- Bluetooth for audio routing (FR-28 / AudioRoutingToggle) -->
    <uses-permission android:name="android.permission.BLUETOOTH" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />

    <!-- Self-managed PhoneAccount for native CallKit-equivalent UX (FR-7, Story 2.5) -->
    <uses-permission android:name="android.permission.MANAGE_OWN_CALLS" />

    <!-- Foreground service for Call lifecycle (Android 14+ requirement, Story 2.5) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_PHONE_CALL" />

    <!-- Incoming Call notifications (FR-7) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Wake-lock for active Call audio capture continuity -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Hardware features -->
    <uses-feature android:name="android.hardware.microphone" android:required="true" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.camera.front" android:required="false" />

    <application
        android:name=".TranslatorRepApplication"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@android:drawable/sym_def_app_icon"
        android:label="@string/app_name"
        android:supportsRtl="false"
        android:theme="@style/Theme.TranslatorRep"
        tools:targetApi="35">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.TranslatorRep"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|uiMode"
            android:screenOrientation="portrait">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
          Story 2.5 will register a self-managed PhoneAccount + ConnectionService
          here for incoming-Call native UI. Declared as placeholder comment until
          that story lands so we don't reference unresolved classes.

          <service
              android:name=".call.incoming.TranslatorRepConnectionService"
              android:permission="android.permission.BIND_TELECOM_CONNECTION_SERVICE"
              android:foregroundServiceType="phoneCall"
              android:exported="true">
              <intent-filter>
                  <action android:name="android.telecom.ConnectionService" />
              </intent-filter>
          </service>

          <service
              android:name=".call.incoming.IncomingCallMessagingService"
              android:exported="false">
              <intent-filter>
                  <action android:name="com.google.firebase.MESSAGING_EVENT" />
              </intent-filter>
          </service>
        -->

    </application>
</manifest>
