# TranslatorRep auth-proxy env vars.
# In production the auth-proxy runs on Render (see docs/runbooks/livekit-cloud-render-setup.md)
# and these are entered as Render secret env vars (NOT a committed file). This file is the
# canonical list + a template for running the auth-proxy locally (`infra/auth-proxy`, copy to
# a gitignored `.env`). The SFU is LiveKit Cloud (the Oracle self-hosting path was dropped).
#
# Populate:
#   - LIVEKIT_WS_URL / LIVEKIT_API_KEY / LIVEKIT_API_SECRET: from your LiveKit Cloud project
#     (cloud.livekit.io → Project → Settings → Keys + the project WS URL). Store in a password manager.
#   - FIREBASE_PROJECT_ID: translatorrep-8d773 (already set in render.yaml for prod).
#   - FIREBASE_SERVICE_ACCOUNT_JSON_BASE64: Firebase console → Project settings → Service accounts →
#     Generate new private key. Save the JSON, then base64 it (one line, no wrapping):
#       PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("path/to/service-account.json"))
#       Bash:       base64 -w 0 service-account.json

# === LiveKit Cloud ===
LIVEKIT_WS_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# === Firebase Admin SDK (used by auth-proxy) ===
FIREBASE_PROJECT_ID=translatorrep-8d773
FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=

# === App Check enforcement (token endpoint) ===
# "true"  (default, production) — /v1/token requires a valid App Check token.
# "false" (dev/testing)        — skip App Check (still requires a Firebase ID token),
#                                so debug builds don't need per-device debug tokens.
APP_CHECK_ENFORCED=true
