# TranslatorRep Oracle VM env vars.
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
#
# Generate fresh values:
#   - LIVEKIT_API_KEY + LIVEKIT_API_SECRET: any random 32-char alphanumeric strings,
#     OR run `docker run --rm livekit/livekit-server generate-keys` on your laptop.
#     The same key/secret pair is used by livekit-server (to authenticate JWTs) AND
#     auth-proxy (to sign JWTs). Store in a password manager.
#   - FIREBASE_SERVICE_ACCOUNT_JSON_BASE64: download from Firebase console →
#     Project settings → Service accounts → Generate new private key. Save the JSON,
#     then base64 it (one line, no wrapping):
#       PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("path/to/service-account.json"))
#       Bash:       base64 -w 0 service-account.json
#     Paste the resulting string below.

# === LiveKit ===
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# === Firebase Admin SDK (used by auth-proxy) ===
FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=
